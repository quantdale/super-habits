# Supabase (optional; app runs local-only if unset)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Command parser (optional real-parser path)
EXPO_PUBLIC_AI_COMMAND_PARSE_MODE=local
EXPO_PUBLIC_AI_COMMAND_INTERNAL_ROLLOUT=false
EXPO_PUBLIC_AI_COMMAND_BACKEND_HOST=default
EXPO_PUBLIC_AI_COMMAND_SUPABASE_FUNCTION_NAME=parse-ai-command
EXPO_PUBLIC_AI_COMMAND_PROXY_URL=

# E2E feature gates
E2E_COMMAND_INTERNAL_OBSERVATION=false
E2E_COMMAND_INTERNAL_EVAL=false
