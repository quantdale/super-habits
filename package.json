{
  "name": "superhabits",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "cross-env EXPO_UNSTABLE_HEADLESS=1 expo start --web",
    "build:web": "npx expo export -p web",
    "deploy:web": "npx expo export --platform web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report .cursor/playwright-output/e2e-report",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@shopify/flash-list": "^2.3.1",
    "@tanstack/react-query": "^5.95.2",
    "date-fns": "^4.1.0",
    "expo": "^55.0.8",
    "expo-background-fetch": "^55.0.10",
    "expo-file-system": "^55.0.11",
    "expo-linear-gradient": "~55.0.9",
    "expo-notifications": "^55.0.13",
    "expo-router": "^55.0.7",
    "expo-sqlite": "^55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-task-manager": "^55.0.10",
    "nativewind": "^4.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-native": "^0.84.1",
    "react-native-css-interop": "^0.2.3",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-reanimated": "^4.2.3",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.0",
    "tailwindcss": "^3.4.19",
    "uuid": "^13.0.0",
    "workbox-window": "^7.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@playwright/test": "^1.58.2",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.12",
    "cross-env": "^10.1.0",
    "patch-package": "^8.0.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1",
    "wait-on": "^9.0.4"
  },
  "private": true
}
