{
  "name": "superhabits",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "cross-env EXPO_UNSTABLE_HEADLESS=1 expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report .cursor/playwright-output/e2e-report",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-community/netinfo": "11.5.2",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.90.21",
    "date-fns": "^4.1.0",
    "expo": "~55.0.5",
    "expo-background-fetch": "^55.0.9",
    "expo-file-system": "^55.0.10",
    "expo-linear-gradient": "~55.0.9",
    "expo-notifications": "^55.0.11",
    "expo-router": "^55.0.4",
    "expo-sqlite": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-task-manager": "^55.0.9",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "tailwindcss": "^3.4.19",
    "uuid": "^13.0.0",
    "workbox-window": "^7.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@playwright/test": "^1.58.2",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.10",
    "cross-env": "^10.1.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.4"
  },
  "private": true
}
