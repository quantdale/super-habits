{
  "name": "superhabits",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "cross-env EXPO_UNSTABLE_HEADLESS=1 expo start --web",
    "build:web": "npx expo export -p web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report .cursor/playwright-output/e2e-report",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.95.2",
    "date-fns": "^4.1.0",
    "expo": "^55.0.8",
    "expo-background-fetch": "^55.0.10",
    "expo-constants": "~55.0.11",
    "expo-crypto": "^55.0.16",
    "expo-file-system": "^55.0.11",
    "expo-font": "~55.0.6",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.11",
    "expo-notifications": "^55.0.13",
    "expo-router": "^55.0.7",
    "expo-sqlite": "^55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-task-manager": "^55.0.10",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-css-interop": "^0.2.3",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^3.4.19",
    "uuid": "^13.0.0",
    "workbox-window": "^7.4.0",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "glob": "^9.3.5",
    "shell-quote": "^1.9.0",
    "axios": "^1.18.1",
    "vite": "^6.2.0",
    "ws@^7.0.0": "7.5.11",
    "ws@^8.0.0": "8.21.0"
  },
  "devDependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@playwright/test": "^1.58.2",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "babel-preset-expo": "^55.0.12",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "patch-package": "^8.0.1",
    "prettier": "^3.9.4",
    "typescript": "~5.9.2",
    "vitest": "^3.2.7",
    "wait-on": "^9.0.4"
  },
  "private": true
}
